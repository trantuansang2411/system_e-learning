generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CourseIndex {
  courseId          String    @id @map("course_id") @db.Uuid
  title            String
  slug             String?   // SEO-friendly URL
  description      String?   @db.Text  // Mô tả ngắn (tối đa 200 ký tự)
  
  // Instructor info
  instructorId     String    @map("instructor_id")
  instructorName   String    @map("instructor_name")
  
  // Categorization
  topicId          String?   @map("topic_id")
  
  // Pricing
  basePrice        Decimal   @map("base_price") @db.Decimal(12, 0)
  salePrice        Decimal   @map("sale_price") @db.Decimal(12, 0)
  currency         String    @default("VND")
  
  // Rating & Reviews
  ratingAvg        Decimal   @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount      Int       @default(0) @map("rating_count")
  
  // Course Stats (quan trọng cho filter)
  totalSections    Int       @default(0) @map("total_sections")
  totalLessons     Int       @default(0) @map("total_lessons")
  totalDurationSec Int       @default(0) @map("total_duration_sec")
  
  // Media
  thumbnailUrl     String?   @map("thumbnail_url")
  
  // Timestamps
  publishedAt      DateTime  @map("published_at") @db.Timestamptz()
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("course_index")
  @@index([topicId])
  @@index([publishedAt])
  @@index([ratingAvg])
  @@index([salePrice])
}
