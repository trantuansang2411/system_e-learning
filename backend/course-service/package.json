{
    "name": "course-service",
    "version": "1.0.0",
    "description": "Course Management Service",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "seed:generate-seed-courses": "node scripts/generate-seed-courses.js",
        "seed:courses": "node scripts/seed.js",
        "seed:courses:file": "node scripts/seed.js ./seed-courses.json",
        "seed:courses:test": "node scripts/seed.js ./seed-courses.test.json",
        "seed:courses:course-only": "set SEED_SYNC_LEARNING=false&& node scripts/seed.js ./seed-courses.json"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.9.13",
        "@grpc/proto-loader": "^0.7.10",
        "amqplib": "^0.10.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.2",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "morgan": "^1.10.0",
        "multer": "^2.1.1",
        "seed": "^0.4.4",
        "slugify": "^1.6.6",
        "kafkajs": "^2.2.4",
        "uuid": "^9.0.0",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "nodemon": "^3.0.2"
    }
}
