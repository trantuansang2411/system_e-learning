generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  studentId String     @unique @map("student_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id            String   @id @default(uuid()) @db.Uuid
  cartId        String   @map("cart_id") @db.Uuid
  courseId       String   @map("course_id") @db.Uuid
  titleSnapshot String   @map("title_snapshot")
  thumbnailUrl  String?  @map("thumbnail_url")
  priceSnapshot Decimal  @map("price_snapshot") @db.Decimal(12, 0)
  instructorId  String?  @map("instructor_id") @db.Uuid
  addedAt       DateTime @default(now()) @map("added_at") @db.Timestamptz()

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, courseId])
  @@map("cart_items")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  studentId       String      @map("student_id") @db.Uuid
  status          String      @default("PENDING") @db.VarChar(16)
  total           Decimal     @db.Decimal(12, 0)
  couponCode      String?     @map("coupon_code") @db.VarChar(32)
  discountAmount  Decimal?    @map("discount_amount") @db.Decimal(12, 0)
  paymentIntentId String?     @map("payment_intent_id") @db.Uuid
  paidAt          DateTime?   @map("paid_at") @db.Timestamptz()
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  items OrderItem[]

  @@index([studentId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id            String  @id @default(uuid()) @db.Uuid
  orderId       String  @map("order_id") @db.Uuid
  courseId       String  @map("course_id") @db.Uuid
  instructorId  String? @map("instructor_id") @db.Uuid
  titleSnapshot String  @map("title_snapshot")
  originalPrice Decimal @map("original_price") @db.Decimal(12, 0)
  finalPrice    Decimal @map("final_price") @db.Decimal(12, 0)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}
